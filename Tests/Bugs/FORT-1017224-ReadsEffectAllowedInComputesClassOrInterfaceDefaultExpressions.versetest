assert_valid:
    vpackage(P, /A, ?UploadedAtFNVersion:=3699):
        snippet:
            # Use an optional instance of an abstract class to define an abstract converges method we can use to test whether reads is allowed
            # in contexts that otherwise require converges.
            abstract_class := class<abstract>:
                Read()<reads><converges>:void
            MaybeInstance:?abstract_class = false

            X:void = option{MaybeInstance?.Read()}

assert_valid:
    vpackage(P, /A, ?UploadedAtFNVersion:=3909):
        snippet:
            # Use an optional instance of an abstract class to define an abstract converges method we can use to test whether reads is allowed
            # in contexts that otherwise require converges.
            abstract_class := class<abstract>:
                Read()<reads><converges>:void
            MaybeInstance:?abstract_class = false

            X:void = option{MaybeInstance?.Read()}

assert_semantic_error(3512):
    vpackage(P, /A, ?UploadedAtFNVersion:=4000):
        snippet:
            # Use an optional instance of an abstract class to define an abstract converges method we can use to test whether reads is allowed
            # in contexts that otherwise require converges.
            abstract_class := class<abstract>:
                Read()<reads><converges>:void
            MaybeInstance:?abstract_class = false

            X:void = option{MaybeInstance?.Read()}

# Test that classes aren't allowed to read from default expressions unless they have the reads/transacts effect.
# We unfortunately can't test computes, as it implicitly retracts <dictates>, and <reads> implicitly grants <dictates>.
# Instead we test <writes> and <allocates>

assert_valid               {vpackage(P, /A, ?UploadedAtFNVersion:=3909){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class{X:void=option{MaybeInstance?.Read()}}}}}
assert_valid               {vpackage(P, /A, ?UploadedAtFNVersion:=4000){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class{X:void=option{MaybeInstance?.Read()}}}}}

assert_valid               {vpackage(P, /A, ?UploadedAtFNVersion:=3909){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class<reads>{X:void=option{MaybeInstance?.Read()}}}}}
assert_valid               {vpackage(P, /A, ?UploadedAtFNVersion:=4000){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class<reads>{X:void=option{MaybeInstance?.Read()}}}}}

assert_valid               {vpackage(P, /A, ?UploadedAtFNVersion:=3909){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class<writes>{X:void=option{MaybeInstance?.Read()}}}}}
assert_semantic_error(3512){vpackage(P, /A, ?UploadedAtFNVersion:=4000){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class<writes>{X:void=option{MaybeInstance?.Read()}}}}}

assert_valid               {vpackage(P, /A, ?UploadedAtFNVersion:=3909){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class<allocates>{X:void=option{MaybeInstance?.Read()}}}}}
assert_semantic_error(3512){vpackage(P, /A, ?UploadedAtFNVersion:=4000){snippet{abstract_class := class<abstract>{Read()<reads><converges>:void}; MaybeInstance:?abstract_class = false; test_class := class<allocates>{X:void=option{MaybeInstance?.Read()}}}}}
