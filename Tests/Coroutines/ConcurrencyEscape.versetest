    spawn{Test(SelfCancelRush, 1, (arm{Delay := 1, Return := option{"X"}}, arm{Delay := 1}, arm{Delay := 1}))}
    Tick(3)
    AssertLog(",azX,3c2b,,", ?BPVM := ",azcX,2bz,,")
